local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")

local sgui = Instance.new("ScreenGui")
sgui.Name = "VampireLagFree"
sgui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 180, 0, 45)
button.Position = UDim2.new(0.75, 0, 0.05, 0) -- มุมบนใกล้แบตเหมือนเดิม
button.BackgroundColor3 = Color3.fromRGB(30, 0, 50) -- สีม่วงเข้มแบบแวมไพร์
button.Text = "เปิดโหมดกันค้าง 🛡️"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Font = Enum.Font.SourceSansBold
button.TextSize = 14
button.Parent = sgui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = button

local active = false

-- 1. ล็อคเลือดแบบ Real-time (ไม่ใช้ Loop ให้หนักเครื่อง)
hum.HealthChanged:Connect(function()
    if active and hum.Health < hum.MaxHealth then
        hum.Health = hum.MaxHealth
    end
end)

-- 2. ระบบสังหารแบบ "ลดภาระเครื่อง"
local function killNearby()
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("Humanoid") and not game.Players:GetPlayerFromCharacter(v.Parent) then
            local root = v.Parent:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (root.Position - char.HumanoidRootPart.Position).Magnitude
                if dist < 70 then -- ระยะ 70 เมตรกำลังดี
                    -- **จุดสำคัญ: ไม่ปรับ Size แล้วเพื่อกันเกมค้าง**
                    -- แต่เราจะสั่งให้ตายทันทีที่เข้าระยะแทน
                    v.Health = 0
                end
            end
        end
    end
end

button.Activated:Connect(function()
    active = not active
    if active then
        button.Text = "แวมไพร์ลื่นๆ! ✅"
        button.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        
        task.spawn(function()
            while active do
                killNearby()
                task.wait(0.5) -- ปรับเป็น 0.5 วินาที เพื่อให้ Infinix ไม่ร้อนจนค้าง
            end
        end)
    else
        button.Text = "เปิดโหมดกันค้าง 🛡️"
        button.BackgroundColor3 = Color3.fromRGB(30, 0, 50)
    end
end)
