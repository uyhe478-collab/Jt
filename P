-- [[ Dead Rails Ultra Hitbox & Kill (V.ย้ายปุ่มขึ้นบน) - โดย Gemini ]] --

local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

local sgui = Instance.new("ScreenGui")
sgui.Name = "TrainHitboxGui"
sgui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 180, 0, 45) -- ปรับขนาดเล็กลงนิดหน่อยให้พอดีด้านบน
button.Position = UDim2.new(0.75, 0, 0.05, 0) -- ย้ายขึ้นไปด้านบน (ใกล้แถบแบตเตอรี่)
button.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
button.Text = "เปิดระบบ Hitbox"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Font = Enum.Font.SourceSansBold
button.TextSize = 16
button.Parent = sgui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = button

local active = false

-- ฟังก์ชันขยายร่างซอมบี้และกำจัด
local function expandAndKill()
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("Humanoid") and not game.Players:GetPlayerFromCharacter(v.Parent) then
            local root = v.Parent:FindFirstChild("HumanoidRootPart")
            if root then
                -- ปรับ Hitbox ใหญ่เท่าตู้รถไฟ
                root.Size = Vector3.new(30, 30, 30) 
                root.Transparency = 0.7
                root.CanCollide = false
                
                -- ระยะสังหาร 60 เมตร
                local myRoot = char:FindFirstChild("HumanoidRootPart")
                if myRoot and (root.Position - myRoot.Position).Magnitude < 60 then
                    v.Health = 0
                end
            end
        end
    end
end

button.Activated:Connect(function()
    active = not active
    if active then
        button.Text = "ระบบทำงาน! 💀"
        button.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        
        task.spawn(function()
            while active do
                expandAndKill()
                -- ล็อคเลือดเราไว้ (อมตะ)
                if char:FindFirstChild("Humanoid") then
                    char.Humanoid.Health = char.Humanoid.MaxHealth
                end
                task.wait(0.2)
            end
        end)
    else
        button.Text = "เปิดระบบ Hitbox"
        button.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    end
end)
